<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Remove .php from URLs
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?request=$1 [QSA,L]
</IfModule>
